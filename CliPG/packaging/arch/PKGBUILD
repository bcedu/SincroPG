pkgname=clipg
pkgver=2.16.3
pkgrel=1
pkgdesc="CliPG application"
arch=('x86_64')
depends=('gtk3' 'glib2' 'alsa-lib')
license=('MIT')
source=("clipg" "clipg.desktop" "clipg.png")
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
    install -Dm755 "$srcdir/clipg" "$pkgdir/usr/bin/clipg"
    install -Dm644 "$srcdir/clipg.desktop" "$pkgdir/usr/share/applications/clipg.desktop"
    install -Dm644 "$srcdir/clipg.png" "$pkgdir/usr/share/icons/hicolor/256x256/apps/clipg.png"
}
